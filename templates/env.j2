{% if labelstudio_postgres_backend_enabled %}
DJANGO_DB={{ labelstudio_environment_variables_django_db }}
POSTGRES_NAME={{ labelstudio_database_name }}
POSTGRES_USER={{ labelstudio_database_username }}
POSTGRES_PASSWORD={{ labelstudio_database_password }}
POSTGRES_PORT={{ labelstudio_database_port }}
POSTGRES_HOST={{ labelstudio_database_hostname }}
{% endif %}

CSRF_TRUSTED_ORIGINS=https://{{ labelstudio_hostname }}
SSRF_PROTECTION_ENABLED={{ labelstudio_environment_variables_ssrf_protection_enabled }}

{% if labelstudio_environment_variables_disable_signup_without_link %}
LABEL_STUDIO_DISABLE_SIGNUP_WITHOUT_LINK={{ labelstudio_environment_variables_disable_signup_without_link }}
LABEL_STUDIO_USERNAME={{ labelstudio_environment_variables_username }}
LABEL_STUDIO_PASSWORD={{ labelstudio_environment_variables_password }}
{% endif %}

{% if labelstudio_minio_backend_enabled %}
MINIO_ROOT_USER={{ labelstudio_environment_variables_minio_root_user }}
MINIO_ROOT_PASSWORD={{ labelstudio_environment_variables_minio_root_password }}
{% endif %}

{{ labelstudio_environment_variables_additional_variables }}
